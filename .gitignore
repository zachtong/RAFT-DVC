# Checkpoints and experimental / synthetic datasets (manual upload only).
# NOTE: these rules are anchored with a leading "/" so they only match the
# repo root. A bare "data/" pattern would also catch src/data/ (source code),
# silently dropping Python modules from Git.
# Legacy pre-Phase-1 experimental volumes (~840 MB)
/data/
# Raw TIF inputs for legacy data generation
/data_tif/
# Phase-1 synthetic NPZ dataset (~60 GB)
/data_phase1/
# Future: Phase-2 128^3 dataset (multi-TB)
/data_phase2/
# Future: Phase-3 256^3 dataset (multi-TB)
/data_phase3/
# Local training checkpoints (upload selected .pth manually)
/checkpoints/

# Reference papers and prior-paper PDFs -- large, not version-controlled here.
/reference/
/Our_previous_paper/

# Per-run / per-feature PDF reports (kept locally, not pushed).
/reports/

# Notebooks (keep .ipynb files but ignore checkpoints)
# *.ipynb  # Uncomment if you don't want to track notebooks

# Temporary
temp/
tmp/
*.tmp

# Claude Code
.claude/

# Third-party reference code
VolRAFT/

# TACC scratch symlink
scratch

# Archive: keep code/config/doc text files tracked, but ignore any large
# binaries (PDFs, checkpoints, volume files) that might land inside.
archive/**/*.pdf
archive/**/*.pth
archive/**/*.ckpt
archive/**/*.npy
archive/**/*.npz
archive/**/*.tif
archive/**/*.tiff
archive/**/*.h5
archive/**/*.hdf5

# Temporary files and debugging
temp_*/
*_preview/
debug_*.py
visualizations/
QUICK_START_CN.md

# Local-only notes (TACC workflow, lessons learned, personal info)
notes/

# paper-1 benchmark artifacts
traditional_DIC_codes/benchmark/data/
traditional_DIC_codes/benchmark/logs/
paper_1/main.pdf
paper_1/*.aux
paper_1/*.bbl
paper_1/*.blg
paper_1/*.log
paper_1/*.out
paper_1/main_article-class.bak.tex
volraft_fixed/__pycache__/
volraft_asreleased/__pycache__/
